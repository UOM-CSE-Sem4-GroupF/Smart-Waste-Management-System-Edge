    {
        "id": "ce45ec40431b8da9",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Sanity",
        "func": "let fill = msg.payload.fill_level_pct;\nlet timestamp = new Date(msg.payload.timestamp).getTime();\nlet now = Date.now();\n\n// Check range\nif (fill < 0 || fill > 100) {\n    return null;\n}\n\n// Check stale data (older than 5 minutes)\nif (now - timestamp > 5 * 60 * 1000) {\n    return null;\n}\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],

    {
        "id": "c6d9dd2e8c7a1c26",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Buffer",
        "func": "let buffer = context.get(\"buffer\") || [];\n\nlet cloudAvailable = flow.get(\"cloudAvailable\");\n\nif (cloudAvailable === undefined) {\n    cloudAvailable = true;\n}\n\nnode.warn(\"cloudAvailable = \" + cloudAvailable);\n\n\nif (!cloudAvailable) {\n    buffer.push(msg);\n\n    if (buffer.length > 1000) {\n        buffer.shift();\n    }\n\n    context.set(\"buffer\", buffer);\n    return null;\n}\n\n// flush buffer\nwhile (buffer.length > 0) {\n    let bufferedMsg = buffer.shift();\n    node.send(bufferedMsg);\n}\n\ncontext.set(\"buffer\", buffer);\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 770,

    {
        "id": "b7917acd605b3b83",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Dedup",
        "func": "let lastMessages = context.get(\"lastMessages\") || {};\n\nlet bin = msg.payload.bin_id;\nlet value = msg.payload.fill_level_pct;\nlet now = Date.now();\n\nif (lastMessages[bin]) {\n    let last = lastMessages[bin];\n    if (last.value === value && (now - last.time < 60000)) {\n        return null; // drop duplicate\n    }\n}\n\nlastMessages[bin] = { value: value, time: now };\ncontext.set(\"lastMessages\", lastMessages);\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],

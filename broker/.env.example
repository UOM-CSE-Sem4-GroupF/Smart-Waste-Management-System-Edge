# Copy this file to .env and fill in your values
# Never commit .env to git

# EMQX dashboard login
EMQX_DASHBOARD_PASSWORD=admin123

# Credentials used by the MQTT->Kafka bridge to connect to EMQX
EMQX_BRIDGE_USERNAME=sensor-device
EMQX_BRIDGE_PASSWORD=sensorpass

# Kafka
KAFKA_BOOTSTRAP=localhost:9092

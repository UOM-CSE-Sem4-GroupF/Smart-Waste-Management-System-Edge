# MQTT Configuration
MQTT_BROKER=your-broker-url-here
MQTT_PORT=1883
MQTT_USER=your-username-here
MQTT_PASSWORD=your-password-here
MQTT_TOPIC_PREFIX=sensors

# Simulation Configuration
# Time compression factor. 60 = 1 real second equals 1 simulated minute.
# Set to 1 for real-time behaviour matching actual ESP32 firmware sleep cycles.
SIM_SPEED_FACTOR=60
SIM_METRICS_PORT=9102
LESHAN_REGISTRY_URL=http://registry:8090
OTA_FAILURE_RATE=0.05
